{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "price": {
      "type": "float"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["files", "images", "videos"]
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "status": {
      "type": "enumeration",
      "enum": ["draft", "published"],
      "default": "published",
      "required": true
    },
    "New": {
      "type": "boolean"
    },
    "author": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "description_en": {
      "type": "richtext"
    },
    "year": {
      "type": "integer"
    },
    "size": {
      "type": "string"
    },
    "medium": {
      "type": "string"
    },
    "technic": {
      "type": "string"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "pages": {
      "type": "integer"
    },
    "copies": {
      "type": "integer"
    },
    "publishing_date": {
      "type": "date"
    },
    "image_hover": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "design": {
      "type": "string"
    },
    "stripe_product_id": {
      "type": "string"
    },
    "stripe_price_id": {
      "type": "string"
    }
  }
}
